{
  "expo": {
    "name": "SecureBin",
    "slug": "SecureBin",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SecureBin uses the camera to photograph items for bin classification.",
        "NSPhotoLibraryUsageDescription": "SecureBin saves scan images to your device."
      }
    },
    "android": {
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a9e8f"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "minSdkVersion": 24,
      "package": "com.websaleem.securebin"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "SecureBin uses the camera to photograph items for bin classification."
        }
      ]
    ],
    "scheme": "securebin",
    "extra": {
      "router": {}
    }
  }
}